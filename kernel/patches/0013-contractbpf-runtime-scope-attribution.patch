+u64 contract_effect_policy_id_for_scope(enum contract_effect_type effect,
+					struct contract_scope_id scope)
+{
+	unsigned long flags;
+	u64 prog_id = 0;
+	int i;
+
+	if (effect >= CONTRACT_EFFECT_MAX)
+		return 0;
+
+	spin_lock_irqsave(&contract_token_lock, flags);
+	for (i = 0; i < CONTRACT_MAX_TOKENS; i++) {
+		if (!contract_token_used[i])
+			continue;
+		if (contract_tokens[i].effect == effect &&
+		    contract_scope_equal(contract_tokens[i].scope, scope)) {
+			prog_id = contract_tokens[i].prog_id;
+			break;
+		}
+	}
+	spin_unlock_irqrestore(&contract_token_lock, flags);
+
+	if (prog_id)
+		return prog_id;
+
+	return contract_effect_policy_id(effect);
+}
