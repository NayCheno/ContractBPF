+struct contract_scope_id contract_task_scope(struct task_struct *task)
+{
+	struct cgroup *cgrp;
+	u64 cgroup_id_value = 0;
+
+	if (!task)
+		return contract_service_scope();
+
+	rcu_read_lock();
+	cgrp = task_dfl_cgroup(task);
+	if (cgrp)
+		cgroup_id_value = cgroup_id(cgrp);
+	rcu_read_unlock();
+
+	if (!cgroup_id_value)
+		return contract_service_scope();
+
+	return contract_scope_from_cgroup_id(cgroup_id_value);
+}
+
+struct contract_scope_id contract_memcg_scope(struct mem_cgroup *memcg)
+{
+	u64 cgroup_id_value = 0;
+
+	if (memcg && memcg->css.cgroup)
+		cgroup_id_value = cgroup_id(memcg->css.cgroup);
+
+	if (!cgroup_id_value)
+		return contract_service_scope();
+
+	return contract_scope_from_cgroup_id(cgroup_id_value);
+}
+
+struct contract_scope_id contract_current_memcg_scope(void)
+{
+	struct contract_scope_id scope;
+	struct mem_cgroup *memcg;
+
+	memcg = get_mem_cgroup_from_current();
+	scope = contract_memcg_scope(memcg);
+	mem_cgroup_put(memcg);
+
+	return scope;
+}
+
+struct contract_scope_id contract_folio_scope(struct folio *folio)
+{
+	struct contract_scope_id scope;
+	struct mem_cgroup *memcg;
+
+	if (!folio)
+		return contract_current_memcg_scope();
+
+	rcu_read_lock();
+	memcg = folio_memcg_rcu(folio);
+	scope = contract_memcg_scope(memcg);
+	rcu_read_unlock();
+
+	return scope;
+}
+
 struct contract_scope_id contract_service_scope(void)
 {
 	struct contract_scope_id scope;
