diff -urN base.copy/kernel/bpf/contractbpf_sched.c current/kernel/bpf/contractbpf_sched.c
--- base.copy/kernel/bpf/contractbpf_sched.c	1970-01-01 00:00:00.000000000 +0000
+++ current/kernel/bpf/contractbpf_sched.c	2026-05-21 18:32:02.210210015 +0000
@@ -0,0 +1,201 @@
+// SPDX-License-Identifier: GPL-2.0
+#include <linux/contractbpf.h>
+#include <linux/debugfs.h>
+#include <linux/kernel.h>
+#include <linux/module.h>
+#include <linux/jiffies.h>
+#include <linux/sched.h>
+#include <linux/sched/ext.h>
+#include <linux/seq_file.h>
+#include <linux/uaccess.h>
+
+#define CONTRACT_SCHED_SCOPE_TYPE 1
+#define CONTRACT_SCHED_SCOPE_PRIMARY 1
+#define CONTRACT_SCHED_PROG_ID 0
+
+static bool contract_sched_gate_enabled;
+static u64 contract_sched_boost_budget = 4;
+static atomic64_t contract_sched_throttled_boosts;
+
+static struct contract_scope_id contract_sched_scope(void)
+{
+	return (struct contract_scope_id){
+		.type = CONTRACT_SCHED_SCOPE_TYPE,
+		.primary_id = CONTRACT_SCHED_SCOPE_PRIMARY,
+	};
+}
+
+static void contract_sched_install_tokens(void)
+{
+	struct contract_scope_id scope = contract_sched_scope();
+	struct contract_effect_token boost = {
+		.prog_id = CONTRACT_SCHED_PROG_ID,
+		.scope = scope,
+		.effect = CONTRACT_EFFECT_SCHED_BOOST,
+		.budget_primary = contract_sched_boost_budget,
+		.degrade_state = CONTRACT_DEGRADE_THROTTLE,
+	};
+	struct contract_effect_token dispatch = {
+		.prog_id = CONTRACT_SCHED_PROG_ID,
+		.scope = scope,
+		.effect = CONTRACT_EFFECT_SCHED_DISPATCH,
+	};
+
+	contract_register_token(&boost);
+	contract_register_token(&dispatch);
+}
+
+void contract_sched_ext_dispatch(struct task_struct *p, u64 requested_slice,
+				 u64 *effective_slice)
+{
+	struct contract_scope_id scope = contract_sched_scope();
+	struct contract_ledger *ledger;
+	u64 queue_delay_us = 0;
+	int ret;
+
+	if (!contract_sched_gate_enabled)
+		return;
+
+	contract_sched_install_tokens();
+
+	ret = contract_effect_gate(CONTRACT_SCHED_PROG_ID,
+				   CONTRACT_EFFECT_SCHED_DISPATCH, scope, 1, 0);
+	if (ret == CONTRACT_DENY)
+		contract_ledger_charge(scope,
+				       CONTRACT_EFFECT_SCHED_DISPATCH, 1, 0);
+
+	if (!requested_slice || requested_slice <= SCX_SLICE_DFL)
+		return;
+
+	if (p->scx.runnable_at)
+		queue_delay_us = jiffies_to_usecs(jiffies - p->scx.runnable_at);
+
+	ret = contract_effect_gate(CONTRACT_SCHED_PROG_ID,
+				   CONTRACT_EFFECT_SCHED_BOOST, scope, 1,
+				   queue_delay_us);
+	if (ret == CONTRACT_ALLOW)
+		return;
+
+	ledger = contract_lookup_ledger(scope);
+	if (!ledger || ledger->degrade_state[CONTRACT_EFFECT_SCHED_BOOST] >=
+		       CONTRACT_DEGRADE_THROTTLE) {
+		*effective_slice = SCX_SLICE_DFL;
+		atomic64_inc(&contract_sched_throttled_boosts);
+	}
+}
+
+static ssize_t contract_sched_enable_write(struct file *file,
+					   const char __user *user_buf,
+					   size_t count, loff_t *ppos)
+{
+	char buf[32];
+	bool enable;
+
+	if (count >= sizeof(buf))
+		return -EINVAL;
+	if (copy_from_user(buf, user_buf, count))
+		return -EFAULT;
+	buf[count] = '\0';
+
+	enable = buf[0] != '0';
+	contract_sched_gate_enabled = enable;
+	if (enable)
+		contract_sched_install_tokens();
+	return count;
+}
+
+static ssize_t contract_sched_enable_read(struct file *file,
+					  char __user *user_buf,
+					  size_t count, loff_t *ppos)
+{
+	char buf[4];
+	int len;
+
+	len = scnprintf(buf, sizeof(buf), "%u\n", contract_sched_gate_enabled);
+	return simple_read_from_buffer(user_buf, count, ppos, buf, len);
+}
+
+static const struct file_operations contract_sched_enable_fops = {
+	.owner = THIS_MODULE,
+	.read = contract_sched_enable_read,
+	.write = contract_sched_enable_write,
+};
+
+static ssize_t contract_sched_budget_write(struct file *file,
+					   const char __user *user_buf,
+					   size_t count, loff_t *ppos)
+{
+	char buf[32];
+	int ret;
+	u64 budget;
+
+	if (count >= sizeof(buf))
+		return -EINVAL;
+	if (copy_from_user(buf, user_buf, count))
+		return -EFAULT;
+	buf[count] = '\0';
+
+	ret = kstrtou64(buf, 0, &budget);
+	if (ret)
+		return ret;
+
+	contract_sched_boost_budget = budget;
+	if (contract_sched_gate_enabled)
+		contract_sched_install_tokens();
+	return count;
+}
+
+static ssize_t contract_sched_budget_read(struct file *file,
+					  char __user *user_buf,
+					  size_t count, loff_t *ppos)
+{
+	char buf[32];
+	int len;
+
+	len = scnprintf(buf, sizeof(buf), "%llu\n", contract_sched_boost_budget);
+	return simple_read_from_buffer(user_buf, count, ppos, buf, len);
+}
+
+static const struct file_operations contract_sched_budget_fops = {
+	.owner = THIS_MODULE,
+	.read = contract_sched_budget_read,
+	.write = contract_sched_budget_write,
+};
+
+static int contract_sched_snapshot_show(struct seq_file *seq, void *v)
+{
+	struct contract_scope_id scope = contract_sched_scope();
+	struct contract_ledger *ledger = contract_lookup_ledger(scope);
+
+	seq_printf(seq, "enabled=%u\n", contract_sched_gate_enabled);
+	seq_printf(seq, "boost_budget=%llu\n", contract_sched_boost_budget);
+	seq_printf(seq, "throttled_boosts=%lld\n",
+		   atomic64_read(&contract_sched_throttled_boosts));
+
+	if (!ledger)
+		return 0;
+
+	seq_printf(seq, "sched_dispatch_events=%lld\n",
+		   atomic64_read(&ledger->sched_dispatch_events));
+	seq_printf(seq, "sched_boost_events=%lld\n",
+		   atomic64_read(&ledger->sched_boost_events));
+	seq_printf(seq, "sched_queue_delay_us=%lld\n",
+		   atomic64_read(&ledger->sched_queue_delay_us));
+	seq_printf(seq, "violations=%lld\n",
+		   atomic64_read(&ledger->violations));
+	seq_printf(seq, "boost_degrade_state=%u\n",
+		   ledger->degrade_state[CONTRACT_EFFECT_SCHED_BOOST]);
+	return 0;
+}
+
+DEFINE_SHOW_ATTRIBUTE(contract_sched_snapshot);
+
+void contract_sched_debugfs_init(struct dentry *root)
+{
+	debugfs_create_file("sched_gate_enable", 0600, root, NULL,
+			    &contract_sched_enable_fops);
+	debugfs_create_file("sched_boost_budget", 0600, root, NULL,
+			    &contract_sched_budget_fops);
+	debugfs_create_file("sched_snapshot", 0444, root, NULL,
+			    &contract_sched_snapshot_fops);
+}
