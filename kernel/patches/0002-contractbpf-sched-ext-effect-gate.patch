diff -urN base.copy/tools/sched_ext/scx_contract_boost.bpf.c current/tools/sched_ext/scx_contract_boost.bpf.c
--- base.copy/tools/sched_ext/scx_contract_boost.bpf.c	1970-01-01 00:00:00.000000000 +0000
+++ current/tools/sched_ext/scx_contract_boost.bpf.c	2026-05-21 18:32:02.235209537 +0000
@@ -0,0 +1,43 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+/*
+ * Intentionally over-aggressive sched_ext policy for ContractBPF validation.
+ * It dispatches every task with a long slice so ContractBPF can throttle the
+ * boost effect without killing the scheduler.
+ */
+#include <scx/common.bpf.h>
+
+char _license[] SEC("license") = "GPL";
+
+#define CONTRACT_BOOST_SLICE_NS (200LLU * 1000 * 1000)
+
+UEI_DEFINE(uei);
+
+s32 BPF_STRUCT_OPS(contract_boost_select_cpu, struct task_struct *p,
+		   s32 prev_cpu, u64 wake_flags)
+{
+	bool is_idle = false;
+	s32 cpu;
+
+	cpu = scx_bpf_select_cpu_dfl(p, prev_cpu, wake_flags, &is_idle);
+	if (is_idle)
+		scx_bpf_dispatch(p, SCX_DSQ_LOCAL, CONTRACT_BOOST_SLICE_NS, 0);
+
+	return cpu;
+}
+
+void BPF_STRUCT_OPS(contract_boost_enqueue, struct task_struct *p, u64 enq_flags)
+{
+	scx_bpf_dispatch(p, SCX_DSQ_GLOBAL, CONTRACT_BOOST_SLICE_NS, enq_flags);
+}
+
+void BPF_STRUCT_OPS(contract_boost_exit, struct scx_exit_info *ei)
+{
+	UEI_RECORD(uei, ei);
+}
+
+SCX_OPS_DEFINE(contract_boost_ops,
+	       .select_cpu	= (void *)contract_boost_select_cpu,
+	       .enqueue		= (void *)contract_boost_enqueue,
+	       .exit		= (void *)contract_boost_exit,
+	       .name		= "contract_boost");
+
diff -urN base.copy/tools/sched_ext/scx_contract_boost.c current/tools/sched_ext/scx_contract_boost.c
--- base.copy/tools/sched_ext/scx_contract_boost.c	1970-01-01 00:00:00.000000000 +0000
+++ current/tools/sched_ext/scx_contract_boost.c	2026-05-21 18:32:02.242209403 +0000
@@ -0,0 +1,41 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+#include <signal.h>
+#include <stdio.h>
+#include <unistd.h>
+#include <bpf/bpf.h>
+#include <scx/common.h>
+#include "scx_contract_boost.bpf.skel.h"
+
+static volatile int exit_req;
+
+static void sigint_handler(int sig)
+{
+	exit_req = 1;
+}
+
+int main(int argc, char **argv)
+{
+	struct scx_contract_boost *skel;
+	struct bpf_link *link;
+	__u64 ecode;
+
+	signal(SIGINT, sigint_handler);
+	signal(SIGTERM, sigint_handler);
+
+	skel = SCX_OPS_OPEN(contract_boost_ops, scx_contract_boost);
+	SCX_OPS_LOAD(skel, contract_boost_ops, scx_contract_boost, uei);
+	link = SCX_OPS_ATTACH(skel, contract_boost_ops, scx_contract_boost);
+
+	while (!exit_req && !UEI_EXITED(skel, uei)) {
+		puts("contract_boost running");
+		fflush(stdout);
+		sleep(1);
+	}
+
+	bpf_link__destroy(link);
+	ecode = UEI_REPORT(skel, uei);
+	scx_contract_boost__destroy(skel);
+
+	return UEI_ECODE_RESTART(ecode) ? 2 : 0;
+}
+
