diff -urN m8-base/kernel/bpf/contractbpf_identity.c m8-current/kernel/bpf/contractbpf_identity.c
--- m8-base/kernel/bpf/contractbpf_identity.c	1970-01-01 00:00:00.000000000 +0000
+++ m8-current/kernel/bpf/contractbpf_identity.c	2026-05-22 12:20:00.000000000 +0000
@@ -0,0 +1,135 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Active ContractBPF identity state.
+ *
+ * The original prototype charged all scheduler and MM effects to prog_id=0 and
+ * a single hard-coded service scope. The ioctl control plane installs concrete
+ * contract policy IDs and cgroup/memcg-derived service scopes; hot paths read
+ * this active identity so ledgers are keyed by the manifest-installed policy
+ * and resolved scope. The nonzero defaults preserve existing debugfs selftests
+ * before userspace installs manifests.
+ */
+#include <linux/contractbpf.h>
+#include <linux/spinlock.h>
+
+#define CONTRACT_DEFAULT_SCOPE_TYPE 1
+#define CONTRACT_DEFAULT_SCOPE_PRIMARY 1
+#define CONTRACT_DEFAULT_SCHED_POLICY_ID 0x4353505343484544ULL /* CSPSCHED */
+#define CONTRACT_DEFAULT_MM_POLICY_ID 0x4353504d4d504f4cULL    /* CSPMMPOL */
+
+struct contract_active_identity {
+	u64 policy_id;
+	struct contract_scope_id scope;
+	bool configured;
+};
+
+static DEFINE_SPINLOCK(contract_identity_lock);
+static struct contract_active_identity contract_sched_identity = {
+	.policy_id = CONTRACT_DEFAULT_SCHED_POLICY_ID,
+	.scope = {
+		.type = CONTRACT_DEFAULT_SCOPE_TYPE,
+		.primary_id = CONTRACT_DEFAULT_SCOPE_PRIMARY,
+	},
+};
+static struct contract_active_identity contract_mm_identity = {
+	.policy_id = CONTRACT_DEFAULT_MM_POLICY_ID,
+	.scope = {
+		.type = CONTRACT_DEFAULT_SCOPE_TYPE,
+		.primary_id = CONTRACT_DEFAULT_SCOPE_PRIMARY,
+	},
+};
+
+static bool contract_effect_is_sched(enum contract_effect_type effect)
+{
+	return effect == CONTRACT_EFFECT_SCHED_BOOST ||
+	       effect == CONTRACT_EFFECT_SCHED_DISPATCH ||
+	       effect == CONTRACT_EFFECT_SCHED_PIN_CPU;
+}
+
+static bool contract_effect_is_mm(enum contract_effect_type effect)
+{
+	return effect == CONTRACT_EFFECT_MM_DEMOTE_PAGE ||
+	       effect == CONTRACT_EFFECT_MM_RECLAIM_HINT ||
+	       effect == CONTRACT_EFFECT_MM_CLASSIFY_REGION;
+}
+
+static struct contract_scope_id contract_default_scope(void)
+{
+	return (struct contract_scope_id){
+		.type = CONTRACT_DEFAULT_SCOPE_TYPE,
+		.primary_id = CONTRACT_DEFAULT_SCOPE_PRIMARY,
+	};
+}
+
+void contract_identity_reset_for_tests(void)
+{
+	unsigned long flags;
+
+	spin_lock_irqsave(&contract_identity_lock, flags);
+	contract_sched_identity.policy_id = CONTRACT_DEFAULT_SCHED_POLICY_ID;
+	contract_sched_identity.scope = contract_default_scope();
+	contract_sched_identity.configured = false;
+	contract_mm_identity.policy_id = CONTRACT_DEFAULT_MM_POLICY_ID;
+	contract_mm_identity.scope = contract_default_scope();
+	contract_mm_identity.configured = false;
+	spin_unlock_irqrestore(&contract_identity_lock, flags);
+}
+
+void contract_note_installed_token(const struct contract_effect_token *token)
+{
+	unsigned long flags;
+
+	if (!token || !token->prog_id || token->effect >= CONTRACT_EFFECT_MAX)
+		return;
+
+	spin_lock_irqsave(&contract_identity_lock, flags);
+	if (contract_effect_is_sched(token->effect)) {
+		contract_sched_identity.policy_id = token->prog_id;
+		contract_sched_identity.scope = token->scope;
+		contract_sched_identity.configured = true;
+	} else if (contract_effect_is_mm(token->effect)) {
+		contract_mm_identity.policy_id = token->prog_id;
+		contract_mm_identity.scope = token->scope;
+		contract_mm_identity.configured = true;
+	}
+	spin_unlock_irqrestore(&contract_identity_lock, flags);
+}
+
+u64 contract_effect_policy_id(enum contract_effect_type effect)
+{
+	u64 policy_id;
+	unsigned long flags;
+
+	spin_lock_irqsave(&contract_identity_lock, flags);
+	if (contract_effect_is_sched(effect))
+		policy_id = contract_sched_identity.policy_id;
+	else if (contract_effect_is_mm(effect))
+		policy_id = contract_mm_identity.policy_id;
+	else
+		policy_id = CONTRACT_DEFAULT_SCHED_POLICY_ID;
+	spin_unlock_irqrestore(&contract_identity_lock, flags);
+
+	return policy_id;
+}
+
+struct contract_scope_id contract_effect_scope(enum contract_effect_type effect)
+{
+	struct contract_scope_id scope;
+	unsigned long flags;
+
+	spin_lock_irqsave(&contract_identity_lock, flags);
+	if (contract_effect_is_sched(effect))
+		scope = contract_sched_identity.scope;
+	else if (contract_effect_is_mm(effect))
+		scope = contract_mm_identity.scope;
+	else
+		scope = contract_default_scope();
+	spin_unlock_irqrestore(&contract_identity_lock, flags);
+
+	return scope;
+}
+
+struct contract_scope_id contract_service_scope(void)
+{
+	struct contract_scope_id scope;
+	unsigned long flags;
+
+	spin_lock_irqsave(&contract_identity_lock, flags);
+	scope = contract_sched_identity.configured ? contract_sched_identity.scope :
+						    contract_mm_identity.scope;
+	spin_unlock_irqrestore(&contract_identity_lock, flags);
+
+	return scope;
+}
