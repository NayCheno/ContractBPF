diff -urN m16-base/kernel/bpf/contractbpf_control.c m16-current/kernel/bpf/contractbpf_control.c
--- m16-base/kernel/bpf/contractbpf_control.c	2026-05-22 14:15:00.000000000 +0000
+++ m16-current/kernel/bpf/contractbpf_control.c	2026-05-22 14:15:00.000000000 +0000
@@ -121,6 +121,27 @@
 
 	return 0;
 }
+
+static long contract_ioctl_set_gate(unsigned long arg)
+{
+	struct contract_ioctl_gate gate;
+	bool enabled;
+
+	if (copy_from_user(&gate, (void __user *)arg, sizeof(gate)))
+		return -EFAULT;
+
+	enabled = gate.enabled != 0;
+	switch (gate.subsystem) {
+	case CONTRACTBPF_SUBSYS_SCHED:
+		contract_sched_set_enabled(enabled);
+		return 0;
+	case CONTRACTBPF_SUBSYS_MM:
+		contract_mm_set_enabled(enabled);
+		return 0;
+	default:
+		return -EINVAL;
+	}
+}
 
 static long contractbpf_ioctl(struct file *file, unsigned int cmd,
 			      unsigned long arg)
@@ -138,6 +159,8 @@
 		return 0;
 	case CONTRACTBPF_IOC_CHARGE_EFFECT:
 		return contract_ioctl_charge_effect(arg);
+	case CONTRACTBPF_IOC_SET_GATE:
+		return contract_ioctl_set_gate(arg);
 	default:
 		return -ENOTTY;
 	}
