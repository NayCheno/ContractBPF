+#define CONTRACTBPF_LOWER_TIER_ADISTANCE	(MEMTIER_ADISTANCE_DRAM * 5)
+
+static int contractbpf_lower_tier_node = NUMA_NO_NODE;
+
+static int __init contractbpf_lower_tier_node_setup(char *str)
+{
+	const char *value = str ? str : "<null>";
+	int node;
+
+	if (!str || kstrtoint(str, 0, &node) || node < 0 ||
+	    node >= MAX_NUMNODES) {
+		pr_warn("memory-tiers: ignoring invalid contractbpf_lower_tier_node=%s\n",
+			value);
+		return 0;
+	}
+
+	contractbpf_lower_tier_node = node;
+	pr_info("memory-tiers: ContractBPF lower-tier node override set to node %d\n",
+		node);
+	return 0;
+}
+early_param("contractbpf_lower_tier_node", contractbpf_lower_tier_node_setup);
