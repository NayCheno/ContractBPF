diff -urN m6-base/kernel/bpf/contractbpf_cross.c m6-current/kernel/bpf/contractbpf_cross.c
--- m6-base/kernel/bpf/contractbpf_cross.c	1970-01-01 00:00:00.000000000 +0000
+++ m6-current/kernel/bpf/contractbpf_cross.c	2026-05-21 19:10:14.901140345 +0000
@@ -0,0 +1,263 @@
+// SPDX-License-Identifier: GPL-2.0
+#include <linux/contractbpf.h>
+#include <linux/debugfs.h>
+#include <linux/kernel.h>
+#include <linux/module.h>
+#include <linux/seq_file.h>
+#include <linux/spinlock.h>
+#include <linux/string.h>
+#include <linux/uaccess.h>
+
+#define CONTRACT_SERVICE_SCOPE_TYPE 1
+#define CONTRACT_SERVICE_SCOPE_PRIMARY 1
+#define CONTRACT_CROSS_REFAULT_THRESHOLD 2
+#define CONTRACT_CROSS_QUEUE_DELAY_US 5000
+#define CONTRACT_CROSS_DEMOTE_THRESHOLD 0
+#define CONTRACT_CROSS_PROG_ID 0
+
+static DEFINE_SPINLOCK(contract_cross_audit_lock);
+static char contract_cross_last_audit[192] =
+	"reason=none revoke=none preserve=none";
+static bool contract_cross_rule_enabled = true;
+static atomic64_t contract_cross_unguarded_runs;
+static atomic64_t contract_cross_guarded_runs;
+
+struct contract_scope_id contract_service_scope(void)
+{
+	return (struct contract_scope_id){
+		.type = CONTRACT_SERVICE_SCOPE_TYPE,
+		.primary_id = CONTRACT_SERVICE_SCOPE_PRIMARY,
+	};
+}
+
+static void contract_cross_set_audit(struct contract_scope_id scope,
+				     const char *reason)
+{
+	unsigned long flags;
+
+	spin_lock_irqsave(&contract_cross_audit_lock, flags);
+	scnprintf(contract_cross_last_audit, sizeof(contract_cross_last_audit),
+		  "scope=%u:%llu:%llu reason=%s revoke=demote_page preserve=sched_dispatch",
+		  scope.type, scope.primary_id, scope.secondary_id, reason);
+	spin_unlock_irqrestore(&contract_cross_audit_lock, flags);
+}
+
+void contract_cross_check(struct contract_scope_id scope)
+{
+	struct contract_ledger *ledger = contract_lookup_ledger(scope);
+	u64 refaults;
+	u64 queue_delay_us;
+	u64 pages_demoted;
+
+	if (!contract_cross_rule_enabled)
+		return;
+
+	if (!ledger)
+		return;
+
+	if (ledger->degrade_state[CONTRACT_EFFECT_MM_DEMOTE_PAGE] >=
+	    CONTRACT_DEGRADE_REVOKE)
+		return;
+
+	refaults = atomic64_read(&ledger->refault_events);
+	queue_delay_us = atomic64_read(&ledger->sched_queue_delay_us);
+	pages_demoted = atomic64_read(&ledger->pages_demoted);
+
+	if (refaults <= CONTRACT_CROSS_REFAULT_THRESHOLD ||
+	    queue_delay_us <= CONTRACT_CROSS_QUEUE_DELAY_US ||
+	    pages_demoted <= CONTRACT_CROSS_DEMOTE_THRESHOLD)
+		return;
+
+	contract_cross_set_audit(scope, "refault+queue_delay+demotion");
+	while (ledger->degrade_state[CONTRACT_EFFECT_MM_DEMOTE_PAGE] <
+	       CONTRACT_DEGRADE_REVOKE)
+		contract_trigger_degrade(CONTRACT_CROSS_PROG_ID,
+					 CONTRACT_EFFECT_MM_DEMOTE_PAGE, scope,
+					 "cross-subsystem invariant");
+}
+
+static int contract_cross_snapshot_show(struct seq_file *seq, void *v)
+{
+	struct contract_scope_id scope = contract_service_scope();
+	struct contract_ledger *ledger = contract_lookup_ledger(scope);
+	unsigned long flags;
+	char audit[sizeof(contract_cross_last_audit)];
+
+	seq_puts(seq, "rule=refault+queue_delay+demotion=>revoke_demote_page\n");
+	seq_printf(seq, "enabled=%u\n", contract_cross_rule_enabled);
+	seq_printf(seq, "scope=%u:%llu:%llu\n", scope.type, scope.primary_id,
+		   scope.secondary_id);
+	seq_printf(seq, "unguarded_runs=%lld\n",
+		   atomic64_read(&contract_cross_unguarded_runs));
+	seq_printf(seq, "guarded_runs=%lld\n",
+		   atomic64_read(&contract_cross_guarded_runs));
+
+	if (ledger) {
+		seq_printf(seq, "sched_queue_delay_us=%lld\n",
+			   atomic64_read(&ledger->sched_queue_delay_us));
+		seq_printf(seq, "pages_demoted=%lld\n",
+			   atomic64_read(&ledger->pages_demoted));
+		seq_printf(seq, "refault_events=%lld\n",
+			   atomic64_read(&ledger->refault_events));
+		seq_printf(seq, "violations=%lld\n",
+			   atomic64_read(&ledger->violations));
+		seq_printf(seq, "sched_degrade_state=%u\n",
+			   ledger->degrade_state[CONTRACT_EFFECT_SCHED_BOOST]);
+		seq_printf(seq, "demote_degrade_state=%u\n",
+			   ledger->degrade_state[CONTRACT_EFFECT_MM_DEMOTE_PAGE]);
+	}
+
+	spin_lock_irqsave(&contract_cross_audit_lock, flags);
+	strscpy(audit, contract_cross_last_audit, sizeof(audit));
+	spin_unlock_irqrestore(&contract_cross_audit_lock, flags);
+	seq_printf(seq, "audit=%s\n", audit);
+	return 0;
+}
+
+DEFINE_SHOW_ATTRIBUTE(contract_cross_snapshot);
+
+static void contract_cross_charge_conflict(struct contract_scope_id scope)
+{
+	contract_ledger_charge(scope, CONTRACT_EFFECT_SCHED_DISPATCH, 4, 0);
+	contract_ledger_charge(scope, CONTRACT_EFFECT_SCHED_BOOST, 8, 12000);
+	contract_ledger_charge(scope, CONTRACT_EFFECT_MM_DEMOTE_PAGE, 8, 8);
+}
+
+static void contract_cross_run_scenario(bool guarded)
+{
+	struct contract_scope_id scope = contract_service_scope();
+
+	contract_reset_for_tests();
+	contract_cross_rule_enabled = guarded;
+	contract_cross_charge_conflict(scope);
+	contract_cross_check(scope);
+
+	if (guarded) {
+		atomic64_inc(&contract_cross_guarded_runs);
+	} else {
+		contract_cross_set_audit(scope,
+					 "unguarded feedback loop observed");
+		atomic64_inc(&contract_cross_unguarded_runs);
+	}
+}
+
+static ssize_t contract_cross_scenario_write(struct file *file,
+					     const char __user *user_buf,
+					     size_t count, loff_t *ppos)
+{
+	char buf[32];
+
+	if (count >= sizeof(buf))
+		return -EINVAL;
+	if (copy_from_user(buf, user_buf, count))
+		return -EFAULT;
+	buf[count] = '\0';
+
+	if (sysfs_streq(buf, "unguarded")) {
+		contract_cross_run_scenario(false);
+		return count;
+	}
+
+	if (sysfs_streq(buf, "guarded")) {
+		contract_cross_run_scenario(true);
+		return count;
+	}
+
+	if (sysfs_streq(buf, "reset")) {
+		contract_reset_for_tests();
+		contract_cross_rule_enabled = true;
+		atomic64_set(&contract_cross_unguarded_runs, 0);
+		atomic64_set(&contract_cross_guarded_runs, 0);
+		contract_cross_set_audit(contract_service_scope(), "reset");
+		return count;
+	}
+
+	return -EINVAL;
+}
+
+static const struct file_operations contract_cross_scenario_fops = {
+	.owner = THIS_MODULE,
+	.write = contract_cross_scenario_write,
+};
+
+static ssize_t contract_cross_enable_write(struct file *file,
+					   const char __user *user_buf,
+					   size_t count, loff_t *ppos)
+{
+	char buf[32];
+
+	if (count >= sizeof(buf))
+		return -EINVAL;
+	if (copy_from_user(buf, user_buf, count))
+		return -EFAULT;
+	buf[count] = '\0';
+
+	contract_cross_rule_enabled = buf[0] != '0';
+	return count;
+}
+
+static ssize_t contract_cross_enable_read(struct file *file,
+					  char __user *user_buf, size_t count,
+					  loff_t *ppos)
+{
+	char buf[4];
+	int len;
+
+	len = scnprintf(buf, sizeof(buf), "%u\n", contract_cross_rule_enabled);
+	return simple_read_from_buffer(user_buf, count, ppos, buf, len);
+}
+
+static const struct file_operations contract_cross_enable_fops = {
+	.owner = THIS_MODULE,
+	.read = contract_cross_enable_read,
+	.write = contract_cross_enable_write,
+};
+
+static int contract_cross_selftest_show(struct seq_file *seq, void *v)
+{
+	struct contract_scope_id scope = contract_service_scope();
+	struct contract_ledger *ledger;
+
+	contract_reset_for_tests();
+	contract_cross_rule_enabled = true;
+	contract_ledger_charge(scope, CONTRACT_EFFECT_SCHED_BOOST, 2, 9000);
+	contract_ledger_charge(scope, CONTRACT_EFFECT_MM_DEMOTE_PAGE, 3, 3);
+	contract_cross_check(scope);
+
+	ledger = contract_lookup_ledger(scope);
+	if (!ledger) {
+		seq_puts(seq, "FAIL cross_ledger_lookup\n");
+		return 0;
+	}
+
+	if (ledger->degrade_state[CONTRACT_EFFECT_MM_DEMOTE_PAGE] <
+	    CONTRACT_DEGRADE_REVOKE) {
+		seq_printf(seq, "FAIL demote_not_revoked state=%u\n",
+			   ledger->degrade_state[CONTRACT_EFFECT_MM_DEMOTE_PAGE]);
+		return 0;
+	}
+
+	if (ledger->degrade_state[CONTRACT_EFFECT_SCHED_BOOST]) {
+		seq_printf(seq, "FAIL sched_effect_degraded state=%u\n",
+			   ledger->degrade_state[CONTRACT_EFFECT_SCHED_BOOST]);
+		return 0;
+	}
+
+	seq_puts(seq,
+		 "PASS cross_scope_shared revoke_demote preserve_sched_dispatch audit_event\n");
+	return 0;
+}
+
+DEFINE_SHOW_ATTRIBUTE(contract_cross_selftest);
+
+void contract_cross_debugfs_init(struct dentry *root)
+{
+	debugfs_create_file("cross_snapshot", 0444, root, NULL,
+			    &contract_cross_snapshot_fops);
+	debugfs_create_file("cross_rule_enable", 0600, root, NULL,
+			    &contract_cross_enable_fops);
+	debugfs_create_file("cross_scenario", 0200, root, NULL,
+			    &contract_cross_scenario_fops);
+	debugfs_create_file("cross_selftest", 0444, root, NULL,
+			    &contract_cross_selftest_fops);
+}
