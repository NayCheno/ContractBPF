+static struct contract_effect_token *
+contract_find_token(u64 prog_id, enum contract_effect_type effect,
+		    struct contract_scope_id scope)
+{
+	int i;
+
+	for (i = 0; i < CONTRACT_MAX_TOKENS; i++) {
+		if (READ_ONCE(contract_token_used[i]) &&
+		    contract_tokens[i].prog_id == prog_id &&
+		    contract_tokens[i].effect == effect &&
+		    contract_scope_equal(contract_tokens[i].scope, scope))
+			return &contract_tokens[i];
+	}
+
+	return NULL;
+}
