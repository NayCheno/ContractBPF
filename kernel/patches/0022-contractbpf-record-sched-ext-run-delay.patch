+++ m22-current/kernel/bpf/contractbpf_sched.c	2026-05-22 16:05:00.000000000 +0000
@@ -96,6 +96,31 @@
 	}
 }
 
+void contract_sched_record_run(struct task_struct *p)
+{
+	struct contract_scope_id scope;
+	u64 queue_delay_us;
+
+	if (!contract_sched_gate_enabled || !p)
+		return;
+
+	scope = contract_task_scope(p);
+	if (!contract_effect_policy_id_for_scope(CONTRACT_EFFECT_SCHED_DISPATCH, scope) ||
+	    !contract_effect_policy_id_for_scope(CONTRACT_EFFECT_SCHED_BOOST, scope))
+		return;
+
+	if (!p->scx.runnable_at || time_before(jiffies, p->scx.runnable_at))
+		return;
+
+	queue_delay_us = jiffies_to_usecs(jiffies - p->scx.runnable_at);
+	if (!queue_delay_us)
+		return;
+
+	contract_ledger_charge(scope, CONTRACT_EFFECT_SCHED_BOOST, 0,
+			       queue_delay_us);
+	contract_cross_check(scope);
+}
