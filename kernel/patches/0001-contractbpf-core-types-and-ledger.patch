diff -urN a/include/linux/contractbpf.h b/include/linux/contractbpf.h
--- a/include/linux/contractbpf.h	1970-01-01 00:00:00.000000000 +0000
+++ b/include/linux/contractbpf.h	2026-05-21 18:13:58.496748097 +0000
@@ -0,0 +1,114 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+#ifndef _LINUX_CONTRACTBPF_H
+#define _LINUX_CONTRACTBPF_H
+
+#include <linux/atomic.h>
+#include <linux/errno.h>
+#include <linux/types.h>
+
+enum contract_effect_type {
+	CONTRACT_EFFECT_SCHED_BOOST,
+	CONTRACT_EFFECT_SCHED_DISPATCH,
+	CONTRACT_EFFECT_SCHED_PIN_CPU,
+	CONTRACT_EFFECT_MM_DEMOTE_PAGE,
+	CONTRACT_EFFECT_MM_RECLAIM_HINT,
+	CONTRACT_EFFECT_MM_CLASSIFY_REGION,
+	CONTRACT_EFFECT_MAX,
+};
+
+enum contract_gate_result {
+	CONTRACT_DENY = -1,
+	CONTRACT_ALLOW = 0,
+	CONTRACT_DEGRADED = 1,
+};
+
+enum contract_degrade_action {
+	CONTRACT_DEGRADE_NONE,
+	CONTRACT_DEGRADE_THROTTLE,
+	CONTRACT_DEGRADE_REVOKE,
+	CONTRACT_DEGRADE_FALLBACK,
+	CONTRACT_DEGRADE_DISABLE_POLICY,
+};
+
+struct contract_scope_id {
+	u32 type;
+	u64 primary_id;
+	u64 secondary_id;
+};
+
+struct contract_effect_cost {
+	u64 primary;
+	u64 secondary;
+};
+
+struct contract_effect_token {
+	u64 prog_id;
+	struct contract_scope_id scope;
+	enum contract_effect_type effect;
+	u64 budget_primary;
+	u64 budget_secondary;
+	u64 epoch_ns;
+	u32 degrade_state;
+};
+
+struct contract_ledger {
+	struct contract_scope_id scope;
+	atomic64_t sched_queue_delay_us;
+	atomic64_t sched_dispatch_failures;
+	atomic64_t sched_boost_events;
+	atomic64_t pages_demoted;
+	atomic64_t refault_events;
+	atomic64_t major_fault_events;
+	atomic64_t fault_latency_us;
+	atomic64_t violations;
+	u64 current_epoch;
+	u32 degrade_state[CONTRACT_EFFECT_MAX];
+};
+
+#ifdef CONFIG_CONTRACTBPF
+int contract_register_token(const struct contract_effect_token *token);
+int contract_effect_gate(u64 prog_id, enum contract_effect_type effect,
+			 struct contract_scope_id scope, u64 cost_primary,
+			 u64 cost_secondary);
+void contract_ledger_charge(struct contract_scope_id scope,
+			    enum contract_effect_type effect, u64 cost_primary,
+			    u64 cost_secondary);
+void contract_trigger_degrade(u64 prog_id, enum contract_effect_type effect,
+			      struct contract_scope_id scope, const char *reason);
+void contract_reset_for_tests(void);
+struct contract_effect_token *contract_lookup_token(u64 prog_id,
+						    enum contract_effect_type effect,
+						    struct contract_scope_id scope);
+struct contract_ledger *contract_lookup_ledger(struct contract_scope_id scope);
+bool contract_would_exceed(struct contract_ledger *ledger,
+			   const struct contract_effect_token *token,
+			   struct contract_effect_cost cost);
+#else
+static inline int contract_register_token(const struct contract_effect_token *token)
+{
+	return -EOPNOTSUPP;
+}
+
+static inline int contract_effect_gate(u64 prog_id,
+				       enum contract_effect_type effect,
+				       struct contract_scope_id scope,
+				       u64 cost_primary, u64 cost_secondary)
+{
+	return CONTRACT_DENY;
+}
+
+static inline void contract_ledger_charge(struct contract_scope_id scope,
+					  enum contract_effect_type effect,
+					  u64 cost_primary, u64 cost_secondary)
+{
+}
+
+static inline void contract_trigger_degrade(u64 prog_id,
+					    enum contract_effect_type effect,
+					    struct contract_scope_id scope,
+					    const char *reason)
+{
+}
+#endif
+
+#endif /* _LINUX_CONTRACTBPF_H */
