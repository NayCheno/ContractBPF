diff -urN a/tools/testing/selftests/contractbpf/contractbpf_selftest.sh b/tools/testing/selftests/contractbpf/contractbpf_selftest.sh
--- a/tools/testing/selftests/contractbpf/contractbpf_selftest.sh	1970-01-01 00:00:00.000000000 +0000
+++ b/tools/testing/selftests/contractbpf/contractbpf_selftest.sh	2026-05-21 18:13:58.517747706 +0000
@@ -0,0 +1,28 @@
+#!/bin/sh
+# SPDX-License-Identifier: GPL-2.0
+
+KSFT_SKIP=4
+DEBUGFS=/sys/kernel/debug
+SELFTEST=$DEBUGFS/contractbpf/selftest
+
+if ! grep -q " $DEBUGFS " /proc/mounts 2>/dev/null; then
+	mount -t debugfs debugfs "$DEBUGFS" 2>/dev/null || true
+fi
+
+if [ ! -r "$SELFTEST" ]; then
+	echo "SKIP: $SELFTEST is not available"
+	exit "$KSFT_SKIP"
+fi
+
+out="$(cat "$SELFTEST")"
+echo "$out"
+
+case "$out" in
+PASS*)
+	exit 0
+	;;
+*)
+	exit 1
+	;;
+esac
+
