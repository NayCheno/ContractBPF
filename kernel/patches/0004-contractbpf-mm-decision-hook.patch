diff -urN m5-base/kernel/bpf/contractbpf_mm.c m5-current/kernel/bpf/contractbpf_mm.c
--- m5-base/kernel/bpf/contractbpf_mm.c	1970-01-01 00:00:00.000000000 +0000
+++ m5-current/kernel/bpf/contractbpf_mm.c	2026-05-21 18:47:06.159904561 +0000
@@ -0,0 +1,403 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Conservative ContractBPF MM front-end.
+ *
+ * This is the M5 prototype path: kernel code validates summarized demotion
+ * and reclaim-hint decisions at effect boundaries. It does not expose mutable
+ * folio state to BPF.
+ */
+#include <linux/atomic.h>
+#include <linux/contractbpf.h>
+#include <linux/debugfs.h>
+#include <linux/kernel.h>
+#include <linux/mm.h>
+#include <linux/module.h>
+#include <linux/seq_file.h>
+#include <linux/uaccess.h>
+
+#define CONTRACT_MM_SCOPE_TYPE 2
+#define CONTRACT_MM_SCOPE_PRIMARY 1
+#define CONTRACT_MM_PROG_ID 0
+#define CONTRACT_MM_SIM_FAULT_LATENCY_US 250
+
+static bool contract_mm_gate_enabled;
+static u64 contract_mm_demote_budget = 8;
+static u64 contract_mm_reclaim_hint_budget = 1024;
+static atomic64_t contract_mm_throttled_demotes;
+static atomic64_t contract_mm_revoked_demotes;
+static atomic64_t contract_mm_no_op_decisions;
+static atomic64_t contract_mm_simulation_runs;
+
+static struct contract_scope_id contract_mm_scope(void)
+{
+	return (struct contract_scope_id){
+		.type = CONTRACT_MM_SCOPE_TYPE,
+		.primary_id = CONTRACT_MM_SCOPE_PRIMARY,
+	};
+}
+
+static void contract_mm_reset_counters(void)
+{
+	atomic64_set(&contract_mm_throttled_demotes, 0);
+	atomic64_set(&contract_mm_revoked_demotes, 0);
+	atomic64_set(&contract_mm_no_op_decisions, 0);
+	atomic64_set(&contract_mm_simulation_runs, 0);
+}
+
+static void contract_mm_install_tokens(void)
+{
+	struct contract_scope_id scope = contract_mm_scope();
+	struct contract_effect_token demote = {
+		.prog_id = CONTRACT_MM_PROG_ID,
+		.scope = scope,
+		.effect = CONTRACT_EFFECT_MM_DEMOTE_PAGE,
+		.budget_primary = contract_mm_demote_budget,
+		.degrade_state = CONTRACT_DEGRADE_THROTTLE,
+	};
+	struct contract_effect_token reclaim_hint = {
+		.prog_id = CONTRACT_MM_PROG_ID,
+		.scope = scope,
+		.effect = CONTRACT_EFFECT_MM_RECLAIM_HINT,
+		.budget_primary = contract_mm_reclaim_hint_budget,
+	};
+
+	contract_register_token(&demote);
+	contract_register_token(&reclaim_hint);
+}
+
+static void contract_mm_record_refault_pages(unsigned int nr_pages)
+{
+	struct contract_ledger *ledger;
+
+	if (!contract_mm_gate_enabled)
+		return;
+
+	ledger = contract_lookup_ledger(contract_mm_scope());
+	if (!ledger)
+		return;
+
+	atomic64_add(nr_pages ?: 1, &ledger->refault_events);
+}
+
+static enum contract_mm_decision
+contract_mm_validate_decision(enum contract_mm_decision decision,
+			      unsigned int nr_pages)
+{
+	struct contract_scope_id scope = contract_mm_scope();
+	struct contract_ledger *ledger;
+	u32 degrade_state = CONTRACT_DEGRADE_REVOKE;
+	int ret;
+
+	if (!contract_mm_gate_enabled)
+		return decision;
+
+	nr_pages = nr_pages ?: 1;
+	contract_mm_install_tokens();
+
+	switch (decision) {
+	case CONTRACT_MM_DEMOTE:
+		ret = contract_effect_gate(CONTRACT_MM_PROG_ID,
+					   CONTRACT_EFFECT_MM_DEMOTE_PAGE,
+					   scope, nr_pages, 0);
+		if (ret == CONTRACT_ALLOW)
+			return CONTRACT_MM_DEMOTE;
+
+		ledger = contract_lookup_ledger(scope);
+		if (ledger)
+			degrade_state = ledger->degrade_state
+				[CONTRACT_EFFECT_MM_DEMOTE_PAGE];
+
+		if (degrade_state >= CONTRACT_DEGRADE_REVOKE)
+			atomic64_add(nr_pages, &contract_mm_revoked_demotes);
+		else
+			atomic64_add(nr_pages, &contract_mm_throttled_demotes);
+
+		return CONTRACT_MM_NO_OP;
+	case CONTRACT_MM_RECLAIM_HINT:
+		ret = contract_effect_gate(CONTRACT_MM_PROG_ID,
+					   CONTRACT_EFFECT_MM_RECLAIM_HINT,
+					   scope, 1, 0);
+		if (ret == CONTRACT_ALLOW)
+			return CONTRACT_MM_RECLAIM_HINT;
+		return CONTRACT_MM_NO_OP;
+	case CONTRACT_MM_KEEP:
+	case CONTRACT_MM_NO_OP:
+	default:
+		return decision;
+	}
+}
+
+bool contract_mm_demote_allowed(unsigned int nr_pages)
+{
+	enum contract_mm_decision decision;
+
+	decision = contract_mm_validate_decision(CONTRACT_MM_DEMOTE, nr_pages);
+	if (decision == CONTRACT_MM_DEMOTE)
+		return true;
+
+	atomic64_add(nr_pages ?: 1, &contract_mm_no_op_decisions);
+	return false;
+}
+
+void contract_mm_record_refault(struct folio *folio)
+{
+	contract_mm_record_refault_pages(folio ? folio_nr_pages(folio) : 1);
+}
+
+void contract_mm_record_major_fault(u64 latency_us)
+{
+	struct contract_ledger *ledger;
+
+	if (!contract_mm_gate_enabled)
+		return;
+
+	ledger = contract_lookup_ledger(contract_mm_scope());
+	if (!ledger)
+		return;
+
+	atomic64_inc(&ledger->major_fault_events);
+	atomic64_add(latency_us, &ledger->fault_latency_us);
+}
+
+static void contract_mm_simulate_bad_demote(unsigned int iterations)
+{
+	unsigned int i;
+
+	if (!iterations)
+		iterations = contract_mm_demote_budget + 4;
+
+	contract_mm_gate_enabled = true;
+	contract_mm_install_tokens();
+
+	for (i = 0; i < iterations; i++) {
+		if (contract_mm_validate_decision(CONTRACT_MM_DEMOTE, 1) ==
+		    CONTRACT_MM_DEMOTE) {
+			contract_mm_record_refault_pages(1);
+			contract_mm_record_major_fault(CONTRACT_MM_SIM_FAULT_LATENCY_US);
+		} else {
+			atomic64_inc(&contract_mm_no_op_decisions);
+		}
+
+		if (contract_mm_validate_decision(CONTRACT_MM_RECLAIM_HINT, 1) !=
+		    CONTRACT_MM_RECLAIM_HINT)
+			atomic64_inc(&contract_mm_no_op_decisions);
+	}
+
+	atomic64_inc(&contract_mm_simulation_runs);
+}
+
+static ssize_t contract_mm_enable_write(struct file *file,
+					const char __user *user_buf,
+					size_t count, loff_t *ppos)
+{
+	char buf[32];
+	bool enable;
+
+	if (count >= sizeof(buf))
+		return -EINVAL;
+	if (copy_from_user(buf, user_buf, count))
+		return -EFAULT;
+	buf[count] = '\0';
+
+	enable = buf[0] != '0';
+	contract_mm_gate_enabled = enable;
+	if (enable)
+		contract_mm_install_tokens();
+	return count;
+}
+
+static ssize_t contract_mm_enable_read(struct file *file, char __user *user_buf,
+				       size_t count, loff_t *ppos)
+{
+	char buf[4];
+	int len;
+
+	len = scnprintf(buf, sizeof(buf), "%u\n", contract_mm_gate_enabled);
+	return simple_read_from_buffer(user_buf, count, ppos, buf, len);
+}
+
+static const struct file_operations contract_mm_enable_fops = {
+	.owner = THIS_MODULE,
+	.read = contract_mm_enable_read,
+	.write = contract_mm_enable_write,
+};
+
+static ssize_t contract_mm_demote_budget_write(struct file *file,
+					       const char __user *user_buf,
+					       size_t count, loff_t *ppos)
+{
+	char buf[32];
+	int ret;
+	u64 budget;
+
+	if (count >= sizeof(buf))
+		return -EINVAL;
+	if (copy_from_user(buf, user_buf, count))
+		return -EFAULT;
+	buf[count] = '\0';
+
+	ret = kstrtou64(buf, 0, &budget);
+	if (ret)
+		return ret;
+
+	contract_mm_demote_budget = budget;
+	if (contract_mm_gate_enabled)
+		contract_mm_install_tokens();
+	return count;
+}
+
+static ssize_t contract_mm_demote_budget_read(struct file *file,
+					      char __user *user_buf,
+					      size_t count, loff_t *ppos)
+{
+	char buf[32];
+	int len;
+
+	len = scnprintf(buf, sizeof(buf), "%llu\n",
+			contract_mm_demote_budget);
+	return simple_read_from_buffer(user_buf, count, ppos, buf, len);
+}
+
+static const struct file_operations contract_mm_demote_budget_fops = {
+	.owner = THIS_MODULE,
+	.read = contract_mm_demote_budget_read,
+	.write = contract_mm_demote_budget_write,
+};
+
+static ssize_t contract_mm_simulate_write(struct file *file,
+					  const char __user *user_buf,
+					  size_t count, loff_t *ppos)
+{
+	char buf[32];
+	unsigned int iterations;
+	int ret;
+
+	if (count >= sizeof(buf))
+		return -EINVAL;
+	if (copy_from_user(buf, user_buf, count))
+		return -EFAULT;
+	buf[count] = '\0';
+
+	ret = kstrtouint(buf, 0, &iterations);
+	if (ret)
+		return ret;
+
+	contract_mm_simulate_bad_demote(iterations);
+	return count;
+}
+
+static const struct file_operations contract_mm_simulate_fops = {
+	.owner = THIS_MODULE,
+	.write = contract_mm_simulate_write,
+};
+
+static int contract_mm_snapshot_show(struct seq_file *seq, void *v)
+{
+	struct contract_ledger *ledger = contract_lookup_ledger(contract_mm_scope());
+
+	seq_puts(seq, "prototype_path=1\n");
+	seq_printf(seq, "enabled=%u\n", contract_mm_gate_enabled);
+	seq_printf(seq, "demote_budget=%llu\n", contract_mm_demote_budget);
+	seq_printf(seq, "throttled_demotes=%lld\n",
+		   atomic64_read(&contract_mm_throttled_demotes));
+	seq_printf(seq, "revoked_demotes=%lld\n",
+		   atomic64_read(&contract_mm_revoked_demotes));
+	seq_printf(seq, "no_op_decisions=%lld\n",
+		   atomic64_read(&contract_mm_no_op_decisions));
+	seq_printf(seq, "simulation_runs=%lld\n",
+		   atomic64_read(&contract_mm_simulation_runs));
+
+	if (!ledger)
+		return 0;
+
+	seq_printf(seq, "pages_demoted=%lld\n",
+		   atomic64_read(&ledger->pages_demoted));
+	seq_printf(seq, "reclaim_hints=%lld\n",
+		   atomic64_read(&ledger->reclaim_hints));
+	seq_printf(seq, "refault_events=%lld\n",
+		   atomic64_read(&ledger->refault_events));
+	seq_printf(seq, "major_fault_events=%lld\n",
+		   atomic64_read(&ledger->major_fault_events));
+	seq_printf(seq, "fault_latency_us=%lld\n",
+		   atomic64_read(&ledger->fault_latency_us));
+	seq_printf(seq, "violations=%lld\n",
+		   atomic64_read(&ledger->violations));
+	seq_printf(seq, "demote_degrade_state=%u\n",
+		   ledger->degrade_state[CONTRACT_EFFECT_MM_DEMOTE_PAGE]);
+	seq_printf(seq, "reclaim_hint_degrade_state=%u\n",
+		   ledger->degrade_state[CONTRACT_EFFECT_MM_RECLAIM_HINT]);
+	return 0;
+}
+
+DEFINE_SHOW_ATTRIBUTE(contract_mm_snapshot);
+
+static int contract_mm_selftest_show(struct seq_file *seq, void *v)
+{
+	struct contract_ledger *ledger;
+
+	contract_reset_for_tests();
+	contract_mm_reset_counters();
+	contract_mm_demote_budget = 3;
+	contract_mm_reclaim_hint_budget = 64;
+	contract_mm_gate_enabled = true;
+	contract_mm_simulate_bad_demote(8);
+
+	ledger = contract_lookup_ledger(contract_mm_scope());
+	if (!ledger) {
+		seq_puts(seq, "FAIL mm_ledger_lookup\n");
+		return 0;
+	}
+
+	if (atomic64_read(&ledger->pages_demoted) != 3) {
+		seq_printf(seq, "FAIL pages_demoted=%lld\n",
+			   atomic64_read(&ledger->pages_demoted));
+		return 0;
+	}
+
+	if (atomic64_read(&ledger->refault_events) != 3 ||
+	    atomic64_read(&ledger->major_fault_events) != 3 ||
+	    atomic64_read(&ledger->fault_latency_us) !=
+		    3 * CONTRACT_MM_SIM_FAULT_LATENCY_US) {
+		seq_printf(seq,
+			   "FAIL fault_accounting refaults=%lld major=%lld latency=%lld\n",
+			   atomic64_read(&ledger->refault_events),
+			   atomic64_read(&ledger->major_fault_events),
+			   atomic64_read(&ledger->fault_latency_us));
+		return 0;
+	}
+
+	if (ledger->degrade_state[CONTRACT_EFFECT_MM_DEMOTE_PAGE] <
+	    CONTRACT_DEGRADE_REVOKE ||
+	    atomic64_read(&contract_mm_revoked_demotes) == 0) {
+		seq_printf(seq, "FAIL demote_revoke state=%u revoked=%lld\n",
+			   ledger->degrade_state[CONTRACT_EFFECT_MM_DEMOTE_PAGE],
+			   atomic64_read(&contract_mm_revoked_demotes));
+		return 0;
+	}
+
+	if (atomic64_read(&ledger->reclaim_hints) != 8) {
+		seq_printf(seq, "FAIL reclaim_hint_preserved=%lld\n",
+			   atomic64_read(&ledger->reclaim_hints));
+		return 0;
+	}
+
+	seq_puts(seq,
+		 "PASS mm_demote_refault revoke_demote preserve_reclaim_hint prototype_path\n");
+	return 0;
+}
+
+DEFINE_SHOW_ATTRIBUTE(contract_mm_selftest);
+
+void contract_mm_debugfs_init(struct dentry *root)
+{
+	debugfs_create_file("mm_gate_enable", 0600, root, NULL,
+			    &contract_mm_enable_fops);
+	debugfs_create_file("mm_demote_budget", 0600, root, NULL,
+			    &contract_mm_demote_budget_fops);
+	debugfs_create_file("mm_simulate_bad_demote", 0200, root, NULL,
+			    &contract_mm_simulate_fops);
+	debugfs_create_file("mm_snapshot", 0444, root, NULL,
+			    &contract_mm_snapshot_fops);
+	debugfs_create_file("mm_selftest", 0444, root, NULL,
+			    &contract_mm_selftest_fops);
+}
