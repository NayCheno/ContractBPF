+#include <linux/math64.h>
+#include <linux/seq_file.h>
 #include <linux/spinlock.h>
 #include <linux/string.h>
 
 #define CONTRACT_MAX_LEDGERS 1024
+#define CONTRACT_LEDGER_STRESS_EVENTS 100000
 
 static DEFINE_SPINLOCK(contract_ledger_lock);
 static struct contract_ledger contract_ledgers[CONTRACT_MAX_LEDGERS];
@@ -170,4 +175,60 @@
 	default:
 		break;
