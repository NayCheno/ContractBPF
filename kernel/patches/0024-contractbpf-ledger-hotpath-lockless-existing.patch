diff -urN m24-base/kernel/bpf/contractbpf_ledger.c m24-current/kernel/bpf/contractbpf_ledger.c
--- m24-base/kernel/bpf/contractbpf_ledger.c	2026-05-22 16:20:00.000000000 +0000
+++ m24-current/kernel/bpf/contractbpf_ledger.c	2026-05-22 16:20:00.000000000 +0000
@@ -4,7 +4,7 @@
 #include <linux/spinlock.h>
 #include <linux/string.h>
 
-#define CONTRACT_MAX_LEDGERS 64
+#define CONTRACT_MAX_LEDGERS 1024
 
 static DEFINE_SPINLOCK(contract_ledger_lock);
 static struct contract_ledger contract_ledgers[CONTRACT_MAX_LEDGERS];
@@ -24,7 +24,21 @@
 	ledger->scope = scope;
 }
 
-static struct contract_ledger *contract_get_or_create_ledger(struct contract_scope_id scope)
+static struct contract_ledger *contract_find_ledger(struct contract_scope_id scope)
+{
+	int i;
+
+	for (i = 0; i < CONTRACT_MAX_LEDGERS; i++) {
+		if (READ_ONCE(contract_ledger_used[i]) &&
+		    contract_scope_equal(contract_ledgers[i].scope, scope))
+			return &contract_ledgers[i];
+	}
+
+	return NULL;
+}
+
+static struct contract_ledger *
+contract_get_or_create_ledger_locked(struct contract_scope_id scope)
 {
 	int i, free_slot = -1;
 
@@ -51,8 +65,12 @@
 	struct contract_ledger *ledger;
 	unsigned long flags;
 
+	ledger = contract_find_ledger(scope);
+	if (ledger)
+		return ledger;
+
 	spin_lock_irqsave(&contract_ledger_lock, flags);
-	ledger = contract_get_or_create_ledger(scope);
+	ledger = contract_get_or_create_ledger_locked(scope);
 	spin_unlock_irqrestore(&contract_ledger_lock, flags);
 	return ledger;
 }
@@ -123,41 +141,36 @@
 	struct contract_ledger *ledger;
 	unsigned long flags;
 
-	spin_lock_irqsave(&contract_ledger_lock, flags);
-
 	if (effect >= CONTRACT_EFFECT_MAX) {
+		spin_lock_irqsave(&contract_ledger_lock, flags);
 		memset(contract_ledgers, 0, sizeof(contract_ledgers));
 		memset(contract_ledger_used, 0, sizeof(contract_ledger_used));
 		spin_unlock_irqrestore(&contract_ledger_lock, flags);
 		return;
 	}
 
-	ledger = contract_get_or_create_ledger(scope);
-	if (!ledger) {
-		spin_unlock_irqrestore(&contract_ledger_lock, flags);
+	ledger = contract_lookup_ledger(scope);
+	if (!ledger)
 		return;
-	}
 
 	switch (effect) {
 	case CONTRACT_EFFECT_SCHED_BOOST:
 		atomic64_add(cost_primary, &ledger->sched_boost_events);
 		atomic64_add(cost_secondary, &ledger->sched_queue_delay_us);
 		break;
 	case CONTRACT_EFFECT_SCHED_DISPATCH:
 		atomic64_add(cost_primary, &ledger->sched_dispatch_events);
 		break;
 	case CONTRACT_EFFECT_MM_DEMOTE_PAGE:
 		atomic64_add(cost_primary, &ledger->pages_demoted);
 		atomic64_add(cost_secondary, &ledger->refault_events);
 		break;
 	case CONTRACT_EFFECT_MM_RECLAIM_HINT:
 		atomic64_add(cost_primary, &ledger->reclaim_hints);
 		break;
 	case CONTRACT_EFFECT_MM_CLASSIFY_REGION:
 	case CONTRACT_EFFECT_SCHED_PIN_CPU:
 	default:
 		break;
 	}
-
-	spin_unlock_irqrestore(&contract_ledger_lock, flags);
 }
