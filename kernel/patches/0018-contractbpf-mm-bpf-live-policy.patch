+static long contract_ioctl_set_mm_bpf_policy(unsigned long arg)
+{
+	struct contract_ioctl_mm_bpf_policy policy;
+	int ret;
+
+	if (copy_from_user(&policy, (void __user *)arg, sizeof(policy)))
+		return -EFAULT;
+
+	ret = contract_mm_register_bpf_policy(policy.prog_fd,
+					      policy.state_map_fd,
+					      &policy.policy_id);
+	if (ret)
+		return ret;
+
+	policy.registered = policy.policy_id != 0;
+	if (copy_to_user((void __user *)arg, &policy, sizeof(policy)))
+		return -EFAULT;
+
+	return 0;
+}
+
+static long contract_ioctl_mm_test_hook(unsigned long arg)
+{
+	struct contract_ioctl_mm_test_hook test;
+	struct contract_scope_id scope;
+	u32 decision = CONTRACT_MM_NO_OP;
+	u32 allowed = 0;
+	int ret;
+
+	if (copy_from_user(&test, (void __user *)arg, sizeof(test)))
+		return -EFAULT;
+
+	ret = contract_mm_test_hook(test.pages, &decision, &allowed, &scope);
+	if (ret)
+		return ret;
+
+	test.decision = decision;
+	test.allowed = allowed;
+	contract_scope_to_ioctl(&test.scope, scope);
+
+	if (copy_to_user((void __user *)arg, &test, sizeof(test)))
+		return -EFAULT;
+
+	return 0;
+}
