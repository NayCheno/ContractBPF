+static bool contract_mm_bpf_map_compatible(struct bpf_map *map)
+{
+	return map && map->map_type == BPF_MAP_TYPE_ARRAY &&
+	       map->key_size == sizeof(u32) &&
+	       map->value_size >= sizeof(struct contract_mm_region_state) &&
+	       map->max_entries >= 1 && map->ops && map->ops->map_update_elem;
+}
+
+int contract_mm_register_bpf_policy(s32 prog_fd, s32 state_map_fd,
+				    u64 *policy_id)
+{
+	struct bpf_prog *new_prog = NULL, *old_prog;
+	struct bpf_map *new_map = NULL, *old_map;
+	u64 new_policy_id = 0;
+	unsigned long flags;
+
+	if (prog_fd < 0 || state_map_fd < 0)
+		goto swap_policy;
+
+	new_prog = bpf_prog_get_type(prog_fd, BPF_PROG_TYPE_SYSCALL);
+	if (IS_ERR(new_prog))
+		return PTR_ERR(new_prog);
+
+	new_map = bpf_map_get(state_map_fd);
+	if (IS_ERR(new_map)) {
+		bpf_prog_put(new_prog);
+		return PTR_ERR(new_map);
+	}
+
+	if (!contract_mm_bpf_map_compatible(new_map)) {
+		bpf_map_put(new_map);
+		bpf_prog_put(new_prog);
+		return -EINVAL;
+	}
+
+	new_policy_id = new_prog->aux ? new_prog->aux->id : 0;
+	if (!new_policy_id) {
+		bpf_map_put(new_map);
+		bpf_prog_put(new_prog);
+		return -EINVAL;
+	}
+
+swap_policy:
+	spin_lock_irqsave(&contract_mm_bpf_lock, flags);
+	old_prog = contract_mm_bpf_prog;
+	old_map = contract_mm_bpf_state_map;
+	contract_mm_bpf_prog = new_prog;
+	contract_mm_bpf_state_map = new_map;
+	WRITE_ONCE(contract_mm_bpf_policy_id, new_policy_id);
+	WRITE_ONCE(contract_mm_bpf_last_decision, CONTRACT_MM_NO_OP);
+	spin_unlock_irqrestore(&contract_mm_bpf_lock, flags);
+
+	if (old_map)
+		bpf_map_put(old_map);
+	if (old_prog)
+		bpf_prog_put(old_prog);
+
+	if (new_policy_id)
+		contract_mm_install_tokens(contract_current_memcg_scope());
+	if (policy_id)
+		*policy_id = new_policy_id;
+	return 0;
+}
+
+static struct contract_mm_region_state
+contract_mm_region_state_from_scope(struct contract_scope_id scope,
+				    struct folio *folio,
+				    unsigned int nr_pages)
+{
+	struct contract_ledger *ledger = contract_lookup_ledger(scope);
+	u64 refaults = 0, major_faults = 0, latency_us = 0;
+
+	if (ledger) {
+		refaults = atomic64_read(&ledger->refault_events);
+		major_faults = atomic64_read(&ledger->major_fault_events);
+		latency_us = atomic64_read(&ledger->fault_latency_us);
+	}
+
+	return (struct contract_mm_region_state){
+		.cgroup_id = scope.primary_id,
+		.memcg_id = scope.primary_id,
+		.region_id = folio ? folio_pfn(folio) : 0,
+		.numa_node = folio ? folio_nid(folio) : 0,
+		.pages = nr_pages ?: 1,
+		.hotness = refaults || major_faults ? 80 : 0,
+		.recent_refaults = min_t(u64, refaults, U32_MAX),
+		.recent_major_faults = min_t(u64, major_faults, U32_MAX),
+		.recent_fault_latency_us = latency_us,
+	};
+}
+
+static enum contract_mm_decision
+contract_mm_bpf_decide(struct contract_scope_id scope, struct folio *folio,
+		       unsigned int nr_pages, enum contract_mm_decision fallback)
+{
+	struct contract_mm_region_state state;
+	struct bpf_prog *prog;
+	struct bpf_map *map;
+	unsigned long flags;
+	u32 key = 0, verdict;
+	long ret;
+
+	state = contract_mm_region_state_from_scope(scope, folio, nr_pages);
+
+	spin_lock_irqsave(&contract_mm_bpf_lock, flags);
+	prog = contract_mm_bpf_prog;
+	map = contract_mm_bpf_state_map;
+	if (!prog || !map) {
+		spin_unlock_irqrestore(&contract_mm_bpf_lock, flags);
+		return fallback;
+	}
+
+	ret = map->ops->map_update_elem(map, &key, &state, BPF_ANY);
+	if (ret) {
+		atomic64_inc(&contract_mm_bpf_failures);
+		spin_unlock_irqrestore(&contract_mm_bpf_lock, flags);
+		return fallback;
+	}
+
+	verdict = bpf_prog_run(prog, NULL);
+	atomic64_inc(&contract_mm_bpf_runs);
+	WRITE_ONCE(contract_mm_bpf_last_decision, verdict);
+	spin_unlock_irqrestore(&contract_mm_bpf_lock, flags);
+
+	if (verdict > CONTRACT_MM_NO_OP) {
+		atomic64_inc(&contract_mm_bpf_invalid_decisions);
+		return fallback;
+	}
+	return verdict;
+}
