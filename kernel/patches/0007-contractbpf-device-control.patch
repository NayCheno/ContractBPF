diff -urN m7-base/include/linux/contractbpf.h m7-current/include/linux/contractbpf.h
--- m7-base/include/linux/contractbpf.h	2026-05-22 12:05:00.000000000 +0000
+++ m7-current/include/linux/contractbpf.h	2026-05-22 12:05:00.000000000 +0000
@@ -4,6 +4,7 @@
 
 #include <linux/atomic.h>
 #include <linux/errno.h>
+#include <linux/ioctl.h>
 #include <linux/types.h>
 
 struct dentry;
@@ -74,6 +75,49 @@
 	CONTRACT_MM_NO_OP,
 };
 
+#define CONTRACTBPF_IOC_MAGIC 0xcb
+
+struct contract_ioctl_scope {
+	u32 scope_type;
+	u32 reserved;
+	u64 primary_id;
+	u64 secondary_id;
+};
+
+struct contract_ioctl_token {
+	u64 prog_id;
+	u32 effect;
+	u32 reserved;
+	struct contract_ioctl_scope scope;
+	u64 budget_primary;
+	u64 budget_secondary;
+	u64 epoch_ns;
+	u32 degrade_state;
+	u32 reserved2;
+};
+
+struct contract_ioctl_snapshot {
+	struct contract_ioctl_scope scope;
+	u64 sched_queue_delay_us;
+	u64 sched_dispatch_events;
+	u64 sched_dispatch_failures;
+	u64 sched_boost_events;
+	u64 pages_demoted;
+	u64 reclaim_hints;
+	u64 refault_events;
+	u64 major_fault_events;
+	u64 fault_latency_us;
+	u64 violations;
+	u32 degrade_state[CONTRACT_EFFECT_MAX];
+};
+
+#define CONTRACTBPF_IOC_INSTALL_TOKEN \
+	_IOW(CONTRACTBPF_IOC_MAGIC, 1, struct contract_ioctl_token)
+#define CONTRACTBPF_IOC_GET_LEDGER \
+	_IOWR(CONTRACTBPF_IOC_MAGIC, 2, struct contract_ioctl_snapshot)
+#define CONTRACTBPF_IOC_RESET_TEST \
+	_IO(CONTRACTBPF_IOC_MAGIC, 3)
+
 #ifdef CONFIG_CONTRACTBPF
 int contract_register_token(const struct contract_effect_token *token);
 int contract_effect_gate(u64 prog_id, enum contract_effect_type effect,
